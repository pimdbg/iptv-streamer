{
  "compilerOptions": {
    "target": "ES2020",
    "outDir": "dist",
    "module": "ESNext",
    "jsx": "react-jsx",
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "traceResolution": false,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@main/*": ["electron/*"],
      "@react/*": ["renderer/*"]    
    },
  },
  "include": ["electron", "shared",]
}